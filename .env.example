# Shared runtime mode
NODE_ENV=development

# Dashboard and API
WEB_PORT=3000
API_HOST=127.0.0.1
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# Local infrastructure
POSTGRES_DB=redner
POSTGRES_USER=redner
POSTGRES_PASSWORD=redner
POSTGRES_PORT=5432
DATABASE_URL=postgresql://redner:redner@localhost:5432/redner
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Deployment defaults (used in later phases)
REDNER_BASE_DOMAIN=localhost
REDNER_PROXY_NETWORK=redner_proxy
REDNER_BUILD_ROOT=/tmp/redner
REDNER_CADDY_CONTAINER=redner-caddy
REDNER_CADDY_ROUTES_DIR=./data/caddy/routes
