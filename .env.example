# Shared runtime mode
NODE_ENV=development

# Dashboard and API
WEB_PORT=3000
API_HOST=127.0.0.1
API_PORT=4000

# Local infrastructure (introduced in Phase 1)
DATABASE_URL=postgresql://redner:redner@localhost:5432/redner
REDIS_URL=redis://localhost:6379

# Deployment defaults (used in later phases)
REDNER_BASE_DOMAIN=localhost
REDNER_PROXY_NETWORK=redner_proxy
REDNER_BUILD_ROOT=/tmp/redner
