# Shared runtime mode
NODE_ENV=development

# Dashboard and API
WEB_PORT=3000
API_HOST=127.0.0.1
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_REDNER_BASE_DOMAIN=localhost
REDNER_INTERNAL_API_URL=http://127.0.0.1:4000

# Local infrastructure
POSTGRES_DB=redner
POSTGRES_USER=redner
POSTGRES_PASSWORD=redner
POSTGRES_PORT=5432
DATABASE_URL=postgresql://redner:redner@localhost:5432/redner
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2
DEPLOYMENT_LOCK_TTL_MS=900000
CLONE_TIMEOUT_MS=120000
BUILD_TIMEOUT_MS=600000
MAX_BUILD_LOG_LINES=2000
MAX_LOG_LINE_LENGTH=4000
MAX_RETAINED_LOG_LINES=5000
HEALTH_TIMEOUT_MS=60000
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=1
CONTAINER_PIDS_LIMIT=128
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Deployment defaults (used in later phases)
REDNER_BASE_DOMAIN=localhost
REDNER_PROXY_NETWORK=redner_proxy
REDNER_BUILD_ROOT=/tmp/redner
REDNER_CADDY_CONTAINER=redner-caddy
REDNER_CADDY_ROUTES_DIR=./data/caddy/routes
CADDY_BIND_ADDRESS=127.0.0.1
CADDYFILE_PATH=./Caddyfile

# Required only when CADDYFILE_PATH=./Caddyfile.production
REDNER_DASHBOARD_DOMAIN=redner.example.com
