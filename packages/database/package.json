    "prisma:status": "prisma migrate status --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@redner/shared": "*",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "dotenv": "^17.2.3",
    "prisma": "^7.8.0"
  }
}
